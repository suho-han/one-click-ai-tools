{
    "name": "one-click-tools",
    "version": "0.4.11",
    "description": "High-performance OS-aware updater for developer AI CLI tools (Go version)",
    "bin": {
        "one-click-tools": "scripts/oct-wrapper.js",
        "oct": "scripts/oct-wrapper.js"
    },
    "scripts": {
        "release": "standard-version",
        "postinstall": "node scripts/postinstall.js",
        "build": "go build -o oct main.go"
    },
    "files": [
        "cmd/",
        "internal/",
        "scripts/",
        "main.go",
        "go.mod",
        "go.sum",
        "README.md",
        "README.en.md",
        "LICENSE"
    ],
    "standard-version": {
        "skip": {
            "tag": false
        },
        "types": [
            {
                "type": "feat",
                "section": "Features"
            },
            {
                "type": "fix",
                "section": "Bug Fixes"
            },
            {
                "type": "chore",
                "hidden": true
            },
            {
                "type": "docs",
                "section": "Documentation"
            },
            {
                "type": "style",
                "hidden": true
            },
            {
                "type": "refactor",
                "section": "Refactors"
            },
            {
                "type": "perf",
                "section": "Performance"
            },
            {
                "type": "test",
                "hidden": true
            }
        ]
    },
    "type": "commonjs",
    "license": "MIT",
    "keywords": [
        "cli",
        "developer-tools",
        "codex",
        "claude",
        "gemini",
        "copilot"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/suho-han/one-click-tools.git"
    },
    "engines": {
        "node": ">=18"
    },
    "os": [
        "darwin",
        "linux"
    ],
    "devDependencies": {
        "standard-version": "^9.5.0"
    },
    "overrides": {
        "handlebars": "4.7.9"
    }
}
